# =============================================
# SemiSignal — 환경 변수 설정 가이드
# =============================================
# 이 파일을 복사하여 .env 파일을 생성하세요.
# cp .env.example .env
# =============================================

# [필수] NewsAPI.org API Key
# 발급: https://newsapi.org/register
VITE_NEWS_API_KEY=your_newsapi_key_here

# [LLM 중 하나 이상 필수] 사용할 LLM의 Key만 입력하면 됩니다.

# Claude API Key (기본값 추천)
# 발급: https://console.anthropic.com/
VITE_CLAUDE_API_KEY=your_claude_key_here

# OpenAI GPT API Key (선택)
# 발급: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_key_here

# Google Gemini API Key (선택)
# 발급: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here

# [회원가입/로그인 필수] Supabase 인증
# 발급: https://supabase.com/dashboard → 프로젝트 → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key_here
